@model CafeWeb.Models.PaymentModel
<head>
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link href="~/CSS/payment.css" rel="stylesheet" />
    <link href="~/CSS/footer.css" rel="stylesheet" />
    <link href="~/CSS/header.css" rel="stylesheet" />
    <style>
        .available {
            color: green;
        }

        .no-available {
            color: red;
        }

        .checking {
            color: gray;
        }
    </style>
    <title> Страница оплаты </title>
</head>
<body>
    <noscript>
        <!-- Отображается только если у пользователя выключен js в браузере -->
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>
    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="/IMG/logo-cafe.png" alt="Logo" onclick="goToPage('/cafe/index')" />
                    </div>
                </div>

                <nav class="header-nav">
                    <a href="/">Главная</a>
                    <a href="/about">О нас</a>
                    <a href="/user/OrderHistory">История заказов</a>
                </nav>

                <div class="header-actions">
                    <button class="btn-backk" onclick="goBackSafe('/cafe/index')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>
    <div class="out-form">
        <form method="post" action="/payment/pay">
            <div class="in-form">
                <label>Введите данные карты:</label> <br />
                <input id="card-number" class="payment-input" type="text" inputmode="numeric" maxlength="19"
                       placeholder="XXXX-XXXX-XXXX-XXXX" autocomplete="cc-number" name="CardNumber" required />
                <br />

                <input id="expiry" class="payment-input" type="text" inputmode="numeric" maxlength="5"
                       placeholder="ММ/ГГ" autocomplete="cc-exp" name="MonthYear" required />

                <input id="cvv" class="payment-input" type="text" inputmode="numeric" maxlength="3"
                       placeholder="CVV" autocomplete="cc-csc" name="CvvCode" required />
                <div class="under-pay">
                    <b>К оплате <span id="total-price" data-original-total="@ViewBag.Total">@ViewBag.Total.ToString("N2")</span> руб.</b>
                    <input id="total-input" hidden value="@ViewBag.Total" name="TotalAmount" style="width: 0px"/>
                    <input id="total-input" hidden value="@ViewBag.Original" name="OriginalAmount" style="width: 0px" />
                    <input name="Promocode" id="promo" class="payment-input" type="text" placeholder="Введите промокод" maxlength="20" />
                    <div id="fetch-response"></div>
                    <br /><button class="btn-pay" type="submit">Оплатить</button>
                </div>
            </div>
        </form>
    </div>
    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Подробнее о нашем кафе</h4>
                    <ul>
                        <li><i class="fas fa-building"></i><a href="/about#about">О нас</a></li>
                        <li><i class="fas fa-history"></i><a href="/about#story">Наша история</a></li>
                        <li><i class="fas fa-gem"></i><a href="/about#cinus">Наши ценности</a></li>
                        <li><i class="fas fa-chart-bar"></i><a href="/about#stats">Наша статистика</a></li>
                        <li><i class="fa-solid fa-pizza-slice"></i><a href="/about#meny">Меню</a></li>

                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Контакты и FAQ</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                        <li><i class="fas fa-question"></i><a href="/faq"> FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
            </div>
        </div>
    </footer>
    <script src="~/JS/PaymentScripts.js"></script>
    <script src="~/JS/backButton.js"></script>
    <script src="~/JS/header.js"></script>
</body>