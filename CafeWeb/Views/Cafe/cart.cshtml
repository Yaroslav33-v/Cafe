@model CafeWeb.Models.Cart
@using System.Text.Json

@{
    // Сериализуем корзину для передачи в JS
    var cartJson = JsonSerializer.Serialize(new
    {
        items = Model.Items.Select(i => new
        {
            id = i.Food.Id,
            name = i.Food.Name,
            price = i.Food.Price,
            quantity = i.Quantity,
            total = i.Total,
            image = i.Food.FrontImageAddress
        }),
        offerItems = Model.OfferItems.Select(o => new
        {
            id = o.Id,
            name = o.Name,
            discount = o.Discount,
            quantity = o.Quantity,
            total = o.Total,
            foods = o.Foods.Select(f => new
            {
                id = f.Id,
                name = f.Name,
                price = f.Price
            })
        }),
        totalAmount = Model.TotalAmount,
        totalItems = Model.TotalItems
    });
}

<!DOCTYPE html>
<html>
<head>
    <title>Корзина - Кафе "4 Творожка"</title>
    <link href="~/CSS/cart.css" rel="stylesheet" />
    <link href="~/CSS/footer.css" rel="stylesheet" />
    <link href="~/CSS/header.css" rel="stylesheet" />
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <noscript>
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>

    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="/IMG/logo-cafe.png" alt="Logo" onclick="goToPage('/cafe/index')" />
                    </div>
                </div>

                <nav class="header-nav">
                    <a href="/">Главная</a>
                    <a href="/about">О нас</a>
                    <a href="/user/OrderHistory">История заказов</a>
                </nav>

                <div class="header-actions">
                    <button class="btn-backk" onclick="goBackSafe('/cafe/index')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="cart-container">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                    <h1 class="cart-title" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none;">Моя корзина</h1>
                    <button class="btn-back" onclick="goToPage('/cafe/index')">
                        <i class="fas fa-arrow-left"></i> Назад в меню
                    </button>
                </div>

                <div id="cart-items-container">
                    @if (!Model.Items.Any() && !Model.OfferItems.Any())
                    {
                        <div class="empty-cart">
                            <div class="empty-cart-icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            <div class="empty-cart-title">Корзина пуста</div>
                            <div class="empty-cart-message">Добавьте блюда из меню, чтобы сделать заказ</div>
                            <button class="btn-continue" onclick="goToPage('/cafe/index')">
                                <i class="fas fa-arrow-left"></i> В меню
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="cart-items" id="cart-items-list">
                            @foreach (var item in Model.Items)
                            {
                                <div class="cart-item" data-item-id="@item.Food.Id" data-item-type="food">
                                    <div class="cart-item-info">
                                        <div class="cart-item-name">@item.Food.Name</div>
                                        <div class="cart-item-price">@item.Food.Price.ToString("N2") ₽</div>
                                        <div class="cart-item-details">@item.Food.Weight г · @item.Food.Calories ккал</div>
                                    </div>
                                    <div class="cart-item-quantity">
                                        <button class="quantity-btn" onclick="updateQuantity(@item.Food.Id, -1)">-</button>
                                        <span class="quantity-value" data-quantity="@item.Food.Id">@item.Quantity</span>
                                        <button class="quantity-btn" onclick="updateQuantity(@item.Food.Id, 1)">+</button>
                                    </div>
                                    <div class="cart-item-total" data-total="@item.Food.Id">
                                        @item.Total.ToString("N2") ₽
                                    </div>
                                </div>
                            }

                            @foreach (var offer in Model.OfferItems)
                            {
                                <div class="cart-item offer-item" data-offer-id="@offer.Id" data-item-type="offer">
                                    <div class="cart-item-info">
                                        <div class="cart-item-name">Акция: @offer.Name</div>
                                        <div class="cart-item-price">Скидка @((offer.Discount * 100).ToString("0"))%</div>
                                        <div class="cart-item-details">
                                            @string.Join(", ", offer.Foods.Select(f => f.Name))
                                        </div>
                                    </div>
                                    <div class="cart-item-quantity">
                                        <button class="quantity-btn" onclick="updateOfferQuantity(@offer.Id, -1)">-</button>
                                        <span class="quantity-value" data-offer-quantity="@offer.Id">@offer.Quantity</span>
                                        <button class="quantity-btn" onclick="updateOfferQuantity(@offer.Id, 1)">+</button>
                                    </div>
                                    <div class="cart-item-total" data-offer-total="@offer.Id">
                                        @offer.Total.ToString("N2") ₽
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="cart-summary">
                            <div class="summary-info">
                                <div class="summary-item">
                                    <div class="summary-label">Всего позиций</div>
                                    <div class="summary-value" id="totalQuantity">@Model.TotalItems</div>
                                </div>
                                <div class="summary-item">
                                    <div class="summary-label">Сумма заказа</div>
                                    <div class="summary-value" id="totalPrice">@Model.TotalAmount.ToString("N2") ₽</div>
                                </div>
                            </div>
                            <div class="summary-actions">
                                <button class="btn-clear" onclick="clearCart()">
                                    <i class="fas fa-trash-alt"></i> Очистить
                                </button>
                                <button class="btn-pay" onclick="goToPage('/payment/index')">
                                    Перейти к оплате <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Подробнее о нашем кафе</h4>
                    <ul>
                        <li><i class="fas fa-building"></i><a href="/about#about">О нас</a></li>
                        <li><i class="fas fa-history"></i><a href="/about#story">Наша история</a></li>
                        <li><i class="fas fa-gem"></i><a href="/about#cinus">Наши ценности</a></li>
                        <li><i class="fas fa-chart-bar"></i><a href="/about#stats">Наша статистика</a></li>
                        <li><i class="fa-solid fa-pizza-slice"></i><a href="/about#meny">Меню</a></li>

                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Контакты и FAQ</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                        <li><i class="fas fa-question"></i><a href="/faq"> FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <!-- Скрипты -->
    <script src="~/JS/header.js"></script>
    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/cart.js"></script>
    <script src="~/JS/backButton.js"></script>

    <script>
        // Функция для обновления интерфейса корзины после изменения
        async function refreshCartUI() {
            try {
                const response = await fetch('/cafe/getcart');
                const data = await response.json();

                if (data.success) {
                    // Обновляем счетчики
                    const totalQuantitySpan = document.getElementById('totalQuantity');
                    const totalPriceSpan = document.getElementById('totalPrice');
                    const cartCountSpan = document.querySelector('.cart-count');

                    if (totalQuantitySpan) totalQuantitySpan.textContent = data.totalItems;
                    if (totalPriceSpan) totalPriceSpan.textContent = data.totalAmount.toFixed(2) + ' ₽';
                    if (cartCountSpan) cartCountSpan.textContent = data.totalItems;

                    // Обновляем отдельные элементы
                    if (data.items) {
                        for (const item of data.items) {
                            const quantitySpan = document.querySelector(`[data-quantity="${item.id}"]`);
                            const totalSpan = document.querySelector(`[data-total="${item.id}"]`);
                            if (quantitySpan) quantitySpan.textContent = item.quantity;
                            if (totalSpan) totalSpan.textContent = item.total.toFixed(2) + ' ₽';
                        }
                    }

                    if (data.offerItems) {
                        for (const offer of data.offerItems) {
                            const quantitySpan = document.querySelector(`[data-offer-quantity="${offer.id}"]`);
                            const totalSpan = document.querySelector(`[data-offer-total="${offer.id}"]`);
                            if (quantitySpan) quantitySpan.textContent = offer.quantity;
                            if (totalSpan) totalSpan.textContent = offer.total.toFixed(2) + ' ₽';
                        }
                    }
                }
            } catch (error) {
                console.error('Ошибка обновления UI корзины:', error);
            }
        }

        // Переопределяем функцию updateQuantity для обновления UI
        const originalUpdateQuantity = updateQuantity;
        window.updateQuantity = async function(id, value) {
            await originalUpdateQuantity(id, value);
            await refreshCartUI();
        };

        // Переопределяем функцию updateOfferQuantity
        const originalUpdateOfferQuantity = updateOfferQuantity;
        window.updateOfferQuantity = async function(id, value) {
            await originalUpdateOfferQuantity(id, value);
            await refreshCartUI();
        };

        // Переопределяем функцию clearCart
        const originalClearCart = clearCart;
        window.clearCart = async function() {
            await originalClearCart();
            setTimeout(() => location.reload(), 500);
        };
    </script>
</body>
</html>