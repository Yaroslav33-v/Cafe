<!-- Страница для отслеживания заказа -->
@model List<CafeWeb.Models.Order> // List используем так как у одного пользователя может быть сразу несколько заказов
@{
    // Получаем userId из Claims
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
}

<!DOCTYPE html>
<html>
    <head>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    </head>
    <body>
    <noscript>
        <!-- Отображается только если у пользователя выключен js в браузере -->
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>
    @if (!Model.Any())
    {
        <p>В данный момент для вас нет ни одного заказа</p>
    }
    else foreach(var order in Model)
    {
        <div class="order">
            <div class="order-status">
                <h3>
                    ЗАКАЗ №
                    <span>@order.Number.ToUpper()</span>
                </h3>
                    <p data-order-id="@order.Id">@order.Status</p>
                <p>
                    Заказ создан:
                    <span>@order.CreatedAt</span>
                </p>
            </div>
            <div class="positions">
                @foreach(var cartItem in order.CartItems)
                {
                    <p>@cartItem.Food.Name x @cartItem.Quantity шт.</p>
                }
                <p>@order.CartItems.Sum(i => i.Total) руб.</p>
            </div>
        </div>
    }
    <script>
        const userId = '@userId';
        let connection;

        async function initializeSignalR() {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/cafeHub")
                .build();

            connection.on("OrderUpdated", (update) => {
                let statusElement = document.querySelector(`[data-order-id="${update.orderId}"]`);
                if (statusElement) {
                    statusElement.textContent = update.status;
                    // Вот здесь меняем стили
                    statusElement.style.color = "green";
                }
            });

            try {
                await connection.start();
                if (userId && userId !== '0') {
                    await connection.invoke("RegisterUser", parseInt(userId));
                }
            } catch (error) {
                console.error("SignalR error:", error);
            }
        }

        if (userId && userId !== '0') {
            initializeSignalR();
        }
    </script>
    </body>
</html>