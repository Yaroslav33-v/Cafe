@model CafeWeb.Models.Order?
@{
    // Получаем userId из Claims
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
}

<!DOCTYPE html>
<html>
<head>
    <title>Мой заказ - Кафе "4 Творожка"</title>
    <link href="~/CSS/myOrder.css" rel="stylesheet" />
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
</head>
<body>
    <noscript>
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>

    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="~/IMG/logo-cafe.png" alt="Logo" />
                    </div>
                    <nav class="header-nav">
                        <a href="/about">О нас</a>
                        <a href="/faq">FAQ</a>
                    </nav>
                </div>
                <div class="header-actions">
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="order-header-page">
                <button class="btn-back" onclick="goToPage('/user/orderhistory')">
                    <i class="fas fa-arrow-left"></i> Назад к истории
                </button>
            </div>

            <input hidden id="userId" value="@userId" />

            @if (Model is null)
            {
                <div class="empty-order">
                    <div class="empty-icon">
                        <i class="fas fa-search"></i>
                    </div>
                    <div class="empty-title">Заказ не найден</div>
                    <div class="empty-message">Возможно, заказ был удалён или вы указали неверный номер</div>
                    <button class="btn-continue" onclick="goToPage('/user/orderhistory')">
                        <i class="fas fa-list"></i> К истории заказов
                    </button>
                </div>
            }
            else
            {
                <div class="order-details">
                    <div class="order-card-large">
                        <div class="order-status-badge @(Model.Status == "Готов" ? "badge-ready" : "badge-progress")" data-order-id="@Model.Id">
                            @Model.Status
                        </div>

                        <div class="order-number-large">
                            ЗАКАЗ № @Model.Number.ToUpper()
                        </div>

                        <div class="order-date-large">
                            <i class="fas fa-calendar-alt"></i>
                            Создан: @Model.CreatedAt.ToString("dd.MM.yyyy в HH:mm")
                        </div>

                        @if(Model.DoneAt is not null)
                        {
                            <div class="order-date-large">
                                <i class="fas fa-calendar-alt"></i>
                                Приготовлен: @Model.DoneAt?.ToString("dd.MM.yyyy в HH:mm")
                            </div>
                        }

                        <div class="order-items-large">
                            <h3>Состав заказа</h3>
                            <div class="items-list">
                                @foreach (var item in Model.CartItems)
                                {
                                    <div class="order-item-large">
                                        <div class="item-info">
                                            <span class="item-name">@item.Food.Name</span>
                                            <span class="item-quantity">x @item.Quantity</span>
                                        </div>
                                        <div class="item-price">
                                            @item.Total.ToString("N2") ₽
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="order-total-large">
                            <span>Общая сумма:</span>
                            <span class="total-amount">@Model.CartItems.Sum(i => i.Total).ToString("N2") ₽</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>

    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Четыре творожка</h4>
                    <p>Кафе честной еды. Готовим с душой с 2020 года.</p>
                </div>
                <div class="footer-col">
                    <h4>Контакты</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
            </div>
        </div>
    </footer>
    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/myOrder.js"></script>
</body>
</html>