@using System.Text.Json
@model List<CafeWeb.Models.Category> 

<!DOCTYPE html>
<html>
<head>
    <title>Кафе "4 Творожка"</title>
    <link href="~/CSS/main.css" rel="stylesheet" />
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="~/IMG/logo-cafe.png" alt="Logo" />
                    </div>
                    <nav class="header-nav">
                        <a href="/about">О нас</a>
                        <a href="/faq">FAQ</a>
                    </nav>
                </div>
                <div class="header-actions">
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <a href="/user/profile" class="user-icon" title="Профиль">
                        <i class="fas fa-user-circle"></i>
                       
                    </a>
                    <button class="login-btn" onclick="goToPage('/user/signin')">Войти</button>

                </div>
                
            </div>
        </div>
        <div class="search-wrapper">
            <div class="search">
                <input type="text" id="searchInput" placeholder="Поиск блюд...">
            </div>
        </div>
    </header>
    <aside>
        <!--Для боковой панели с переходами по меткам-->
    </aside>
    <main class="main-content">
        <div class="container">
            @if(Model != null && Model.Any())
            {
                <div class="main-menu">
                    @foreach(var category in Model)
                    {
                        <div class="menu-category" data-category-name="@category.Name">

                            <h1>@category.Name</h1>
                            <div class="category-items">
                                @foreach(var food in category.Foods)
                                {
                                    <div class="card" data-card-id="@food.Id">
                                        <div onclick="openFoodModal(@JsonSerializer.Serialize(food), this)">
                                            <div class="card-images">
                                                <img id="front-img" width="300" height="200" src="@Url.Content($"~{food.FrontImageAddress}")" alt="@food.Name" class="front-image" />
                                                <img id="back-img" width="300" height="200" src="@Url.Content($"~{food.BackImageAddress}")" alt="@food.Name" class="back-image" />
                                            </div>
                                            <span class="card-title">@food.Name</span>
                                        </div>
                                
                                        <button class="addCart" type="button" onclick="addToCart(@food.Id)">Добавить в корзину</button>
                                        <button class="modal-food-fav-btn" type="button" onclick="updateFavourite(@food.Id, this)"> </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </main>
    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Четыре творожка</h4>
                    <p>Кафе честной еды. Готовим с душой с 2020 года. От сырников до бургеров — каждый найдёт своё.</p>
                </div>
                <div class="footer-col">
                    <h4>Контакты</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
                <img id="admin-relocation" src="~/IMG/crybady.jpg" />
            </div>
        </div>
    </footer>
    <dialog id="food-modal" >
        <div id="food-info">
            
            <h1 id="modal-food-name"></h1>
            <img id="modal-food-img-front" width="300" height="200" />
            <img id="modal-food-img-back" width="300" height="200" />

            <div>
          
                <p> Вес: <span id="modal-food-weight"></span> г.</p>
                <p id="modal-food-desc"></p>
                <p>Ингредиенты: <span id="modal-food-ingredients"></span></p>
                <p><span id="modal-food-calories"></span> ккал. на 100г. продукта</p>

            </div>
        </div>
        <div id="modal-controls">
            <button id="modal-food-cart-btn" type="button">Добавить <span id="modal-food-price"></span> р. </button>
            <button class="modal-food-fav-btn" type="button"></button>
            <button id="close-btn" type="button">Закрыть</button>
        </div>
    </dialog>
    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/main.js"></script>
    <script src="~/JS/checkRole.js"></script>
    <script src="~/JS/Search.js"></script>
    <script src="~/JS/cookieConsent.js"></script>
</body>
</html>