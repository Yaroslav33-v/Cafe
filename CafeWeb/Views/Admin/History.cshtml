@model List<CafeWeb.Models.Order>

<html>
    <head>
        <title>История заказов пользователей - Кафе "4 Творожка"</title>
        <link href="~/CSS/history-admin.css" rel="stylesheet" />
        <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    </head>

    <body>
        <noscript>
            <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
                Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
            </div>
        </noscript>

        <main class="main-content">
            <div class="container">
                <div class="history-header">
                    <button class="btn-back" onclick="goToPage('/admin/index')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                    <h1 class="history-title">История заказов пользователей</h1>
                </div>

                @foreach(var order in Model)
                {
                    <div class="order-card">
                        <h1>@order.Login</h1>
                        <div class="order-header">
                            <div class="order-number">
                                ЗАКАЗ № @order.Number.ToUpper()
                            </div>
                            <div class="order-status @(order.Status == "Готов" ? "status-ready" : "status-progress")">
                                @order.Status
                            </div>
                        </div>
                        <div class="order-date">
                            <i class="fas fa-calendar-alt"></i>
                            @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </div>
                        <div class="order-items">
                            @{
                                var firstItems = order.CartItems.Take(3).ToList();
                                var remainingCount = order.CartItems.Count - 3;
                            }
                            @foreach (var item in firstItems)
                            {
                                <div class="order-item">
                                    <span class="item-name">@item.Food.Name</span>
                                    <span class="item-quantity">x @item.Quantity</span>
                                    <span class="item-price">@item.Total.ToString("N2") ₽</span>
                                </div>
                            }
                            @if (remainingCount > 0)
                            {
                                <div class="order-more">
                                    <i class="fas fa-ellipsis-h"></i> и ещё @remainingCount позиция(ий)
                                </div>
                            }
                        </div>
                        <div class="order-footer">
                            <div class="order-total">
                                <span>Итого:</span>
                                <span class="total-amount">@order.CartItems.Sum(i => i.Total).ToString("N2") ₽</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </main>
        <script src="~/JS/goToPage.js"></script>
    </body>
</html>