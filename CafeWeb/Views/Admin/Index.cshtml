<!-- Основное меню админов, откуда можно перейти на все остальные админские страницы -->
<html>
	<head>
		<link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
		<link href="~/CSS/admin-main.css" rel="stylesheet" />
		<title> Админские угодия </title>
	</head>
	<body>
	<noscript>
		<!-- Отображается только если у пользователя выключен js в браузере -->
		<div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
			Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
		</div>
	</noscript>
		<div class="container">
			<div class="container-content">
				<img id="logo"src="~/IMG/logo-cafe.png" />
				<label> Выберите операцию:</label>
				<div class="content-row">
				<button class="food" onclick="goToPage('/admin/addfood')">Добавить новое блюдо</button>
				<button class="admin" onclick="goToPage('/admin/newadmin')">Добавить нового админа</button>
				<button class="offer" onclick="goToPage('/admin/newoffer')">Добавить новую акцию</button>
				<button class="promo" onclick="goToPage('/admin/newpromo')">Добавить новый промокод</button>
					
				</div>
			<button class="exit" onclick="goToPage('/cafe/index')">Вернуться на главную</button>
			</div>
		</div>
		
		<script src="~/JS/goToPage.js"></script>
	</body>
</html>