<!-- Страница для добавления новой еды -->
@model CafeWeb.Models.AdminFoodModel

<form method="post" action="/Admin/AddFood" enctype="multipart/form-data">
    <p>@ViewBag.Problem</p> <br/>
    @if (Model.Categories != null && Model.Categories.Any())
    {
        <label>Категория: </label>
        <select name="SelectedCategory">
        @foreach(var category in Model.Categories)
        {
            <option value="@category">@category</option>
        }
        </select> <br />
    }
    else
    {
         <p>Не удалось получить список категорий</p> <br />
    }

    <label>Название: </label> <br />
    <input type="text" name="Food.Name" value="@Model?.Food?.Name" maxlength="100" required /> <br />

    <label>Цена: </label> <br />
    <input type="number" name="Food.Price" value="@Model?.Food?.Price" max="99999.99" min="0" required /> <br />

    <label>Калории: </label> <br />
    <input type="number" name="Food.Calories" value="@Model?.Food?.Calories" max="99999.99" min="0" required /> <br />

    <label>Вес: </label> <br />
    <input type="number" name="Food.Weight" value="@Model?.Food?.Weight" max="99999.99" min="0" required /> <br />

    <label>Ингредиенты:</label> <br />
    <textarea name="Food.Ingredients" value="@Model?.Food?.Ingredients" required></textarea> <br />

    <label>Фото: </label> <br />
    <input type="file" name="Photo" id="fileInput" accept="image/*" value="@Model?.Photo" required /> <br />

    <button type="submit">Добавить</button>
</form>