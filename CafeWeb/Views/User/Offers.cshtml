@using System.Text.Json
@model List<CafeWeb.Models.OfferUserModel>

<!--Акции как купоны в кфс-->
<!--Акции для которых продукты не добавлены дейтсвует как акция в обычном понимании, но при выполнени условий-->
<!--Например: Скидка в честь ДР-->

<!DOCTYPE html>
<html>
    <head>
        <title>Акции</title>
        <link href="~/CSS/offers.css" rel="stylesheet" />
        <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        
    </head>
    <body>
        <noscript>
            <!-- Отображается только если у пользователя выключен js в браузере -->
            <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
                Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
            </div>
        </noscript>
        <header>
            <div class="header-top">
                <div class="header-content">
                    <div class="header-left">
                        <div class="logo">
                            <img src="~/IMG/logo-cafe.png" alt="Logo" onclick="goToPage('/cafe/index')" />  
                            <h1>Добро пожаловать в акции</h1>
                        </div>

                    </div>
                </div>
            </div>
        </header>
        <div class="main-content">
            <div class="container">
            
                <h1>Доступные акции</h1>
                @if(Model is null || !Model.Any())
                {
                    <div id="none-offer">
                        <p class="mes">В данный момент нет доступных акций</p>
                        <p class="mes">Но ты можешь найти что-нибудь интресное в меню!</p>
                        <button class="btn-go" onclick="goToPage('/cafe/index')">Посмотреть меню</button>
                    </div>
                }
                else foreach(var offer in Model)
                {
                    <div class="main-menu">
                  
                        <div class="offer-card">
                            <div class="offer-info">
                            
                                <h3>Акция @offer.Offer.Name</h3>
                                <p>@offer.Offer.Description</p>
                            
                            
                                    @if(offer.Foods is not null && offer.Foods.Any())
                                    {
                                        <p>В акцию входят следующие товары: </p>
                                        <ul>
                                            @foreach (var food in offer.Foods)
                                            {
                                                <li data-food-id="@food.Id">@food.Name</li>
                                            }
                                        </ul>
                                        <div class="offer-price">
                                            <p>Цена: <span>@offer.Foods.Sum(f => f.Price * (1 - offer.Offer.Discount)).ToString("N2")</span></p>
                                        </div>
                                        <button onclick="addToCart('@offer.Offer.Name', @offer.Offer.Id, @JsonSerializer.Serialize(offer.Foods.Select(f => f.Id)), @offer.Offer.Discount)">Добавить в корзину</button>
                                    }
                                    else
                                    {
                                        <div class="discount-badge">
                                           <p>
                                               Акция со скидкой
                                                <span>@(offer.Offer.Discount * 100)%</span>
                                            </p>
                                        </div>
                                        <p>Акция распространяется на все товары, но только при соблюдении условий!</p>
                                        <div class="offer-date"> 
                                    
                                            <p>
                                         
                                                Действует с
                                                <span>@offer.Offer.StartsAt.ToString("dd-MM-yyyy")</span> 
                                                до <span>@offer.Offer.EndsAt.ToString("dd-MM-yyyy")</span>
                                            </p>
                                        </div>
                                    }
                            
                            </div>
                        </div>
                   
                    </div>
                }
                <div class="bottom">
                    <button id="exit" onclick="goToPage('/user/me')"> Назад </button>
                </div>
            </div>
        </div>
        <script src="~/JS/showNotification.js"></script>
        <script src="~/JS/addOfferToCart.js"></script>
        <script src="~/JS/goToPage.js"></script>
    </body>
</html>