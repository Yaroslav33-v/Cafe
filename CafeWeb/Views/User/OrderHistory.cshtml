@model List<CafeWeb.Models.Order>

<!DOCTYPE html>
<html>
<head>
    <title>История заказов - Кафе "4 Творожка"</title>
    <link href="~/CSS/orderHistory.css" rel="stylesheet" />
    <link href="~/CSS/footer.css" rel="stylesheet" />
    <link href="~/CSS/header.css" rel="stylesheet" />
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <noscript>
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>

    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="/IMG/logo-cafe.png" alt="Logo" onclick="goToPage('/cafe/index')" />
                    </div>
                </div>

                <nav class="header-nav">
                    <a href="/">Главная</a>
                    <a href="/about">О нас</a>
                    <a href="/user/OrderHistory">История заказов</a>
                </nav>

                <div class="header-actions">
                    <button class="btn-backk" onclick="goBackSafe('/cafe/index')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="history-header">
                <button class="btn-back" onclick="goToPage('/user/me')">
                    <i class="fas fa-arrow-left"></i> Назад в профиль
                </button>
                <h1 class="history-title">История заказов</h1>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-history">
                    <div class="empty-icon">
                        <i class="fas fa-receipt"></i>
                    </div>
                    <div class="empty-title">У вас пока нет заказов</div>
                    <div class="empty-message">Перейдите в меню и сделайте первый заказ!</div>
                    <button class="btn-continue" onclick="goToPage('/cafe/index')">
                        <i class="fas fa-utensils"></i> В меню
                    </button>
                </div>
            }
            else
            {
                <div class="orders-list">
                    @foreach (var order in Model)
                    {
                        <div class="order-card">
                            <div class="order-header">
                                <div class="order-number">
                                    ЗАКАЗ № @order.Number.ToUpper()
                                </div>
                                <div class="order-status @(order.Status == "Готов" ? "status-ready" : "status-progress")">
                                    @order.Status
                                </div>
                            </div>
                            <div class="order-date">
                                <i class="fas fa-calendar-alt"></i>
                                @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </div>
                            <div class="order-items">
                                @{
                                    var firstItems = order.CartItems.Take(3).ToList();
                                    var remainingCount = order.CartItems.Count - 3;
                                }
                                @foreach (var item in firstItems)
                                {
                                    <div class="order-item">
                                        <span class="item-name">@item.Food.Name</span>
                                        <span class="item-quantity">x @item.Quantity</span>
                                        <span class="item-price">@item.Total.ToString("N2") ₽</span>
                                    </div>
                                }
                                @if (remainingCount > 0)
                                {
                                    <div class="order-more">
                                        <i class="fas fa-ellipsis-h"></i> и ещё @remainingCount позиция(ий)
                                    </div>
                                }
                            </div>
                            <div class="order-footer">
                                <div class="order-actions">
                                    <button class="btn-details" onclick="goToPage('/cafe/myorder?orderId=@order.Id')">
                                        <i class="fas fa-info-circle"></i> Подробнее
                                    </button>
                                </div>
                                <div class="order-total">
                                    <span>Итого:</span>
                                    <span class="total-amount">@order.CartItems.Sum(i => i.Total).ToString("N2") ₽</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </main>

    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Подробнее о нашем кафе</h4>
                    <ul class="footer-nav">
                        <li><i class="fas fa-building"></i><a href="#" data-section="0" data-section-id="about">О нас</a></li>
                        <li><i class="fas fa-history"></i><a href="#" data-section="1" data-section-id="history">Наша история</a></li>
                        <li><i class="fas fa-gem"></i><a href="#" data-section="2" data-section-id="cinus">Наши ценности</a></li>
                        <li><i class="fas fa-chart-bar"></i><a href="#" data-section="3" data-section-id="stats">Наша статистика</a></li>
                        <li><i class="fa-solid fa-pizza-slice"></i><a href="#" data-section="4" data-section-id="menu">Меню</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Контакты и FAQ</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                        <li><i class="fas fa-question"></i><a href="/faq"> FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
            </div>
        </div>
    </footer>

    <script src="~/JS/header.js"></script>
    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/backButton.js"></script>
    <script src="~/JS/footerNav.js"></script>
</body>
</html>