@model List<CafeWeb.Models.Order>

<!DOCTYPE html>
<html>
<head>
    <title>История заказов - Кафе "4 Творожка"</title>
    <link href="~/CSS/order-history.css" rel="stylesheet" />
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <noscript>
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>

    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="~/IMG/logo-cafe.png" alt="Logo" />
                    </div>
                    <nav class="header-nav">
                        <a href="/about">О нас</a>
                        <a href="/faq">FAQ</a>
                    </nav>
                </div>
                <div class="header-actions">
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="container">
            <div class="orders-container">
                <div class="page-header">
                    <h1 class="page-title">История заказов</h1>
                    <button class="btn-back" onclick="goToPage('/user/me')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="fas fa-receipt"></i>
                        </div>
                        <div class="empty-title">История пуста</div>
                        <div class="empty-message">Вы пока не сделали ни одного заказа</div>
                        <button class="btn-continue" onclick="goToPage('/cafe/index')">
                            <i class="fas fa-utensils"></i> В меню
                        </button>
                    </div>
                }
                else
                {
                    foreach (var order in Model)
                    {
                        <div class="order-card">
                            <div class="order-header">
                                <div class="order-number">
                                    ЗАКАЗ № <span>@order.Number.ToUpper()</span>
                                </div>
                                @{
                                    string statusClass = order.Status switch
                                    {
                                        "Готов" => "готов",
                                        "Готовится" => "готовится",
                                        "Ожидает оплаты" => "ожидает",
                                        "Ошибка оплаты" => "ошибка",
                                        _ => "ожидает"
                                    };
                                }
                                <div class="order-status status-@statusClass">
                                    @order.Status
                                </div>
                                <div class="order-date">
                                    <i class="far fa-calendar-alt"></i> @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </div>

                            <div class="order-items">
                                @foreach (var cartItem in order.CartItems.Take(3))
                                {
                                    <div class="order-item">
                                        <span class="order-item-name">@cartItem.Food.Name</span>
                                        <span class="order-item-quantity">x @cartItem.Quantity шт.</span>
                                        <span class="order-item-price">@cartItem.Total.ToString("N2") ₽</span>
                                    </div>
                                }
                                @if (order.CartItems.Count > 3)
                                {
                                    <div class="order-item">
                                        <span class="order-item-more">и ещё @(order.CartItems.Count - 3) позиция(ий)...</span>
                                        <span class="order-item-quantity"></span>
                                        <span class="order-item-price"></span>
                                    </div>
                                }
                            </div>

                            <div class="order-footer">
                                <button class="btn-details" onclick="goToPage('/cafe/myorder?orderId=@order.Id')">
                                   Подробнее
                                </button>
                                <div class="order-total">
                                    <span class="order-total-label">Итого:</span>
                                    <span class="order-total-value">@order.CartItems.Sum(i => i.Total).ToString("N2") ₽</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Четыре творожка</h4>
                    <p>Кафе честной еды. Готовим с душой с 2020 года. От сырников до бургеров — каждый найдёт своё.</p>
                </div>
                <div class="footer-col">
                    <h4>Контакты</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
                <img id="admin-relocation" src="~/IMG/crybady.jpg" />
            </div>
        </div>
    </footer>

    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/main.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            let user = await getUserData();
            const profileActionsDiv = document.getElementById('profile-actions');

            if (profileActionsDiv) {
                if (user.name) {
                    const safeName = sanitizeHtml(user.name);
                    profileActionsDiv.innerHTML = `
                        <a href="/user/me" class="user-icon" title="Профиль">
                            <i class="fas fa-user-circle"></i>
                            <span class="username">${safeName}</span>
                        </a>`;
                } else {
                    profileActionsDiv.innerHTML = `
                        <button class="login-btn" onclick="goToPage('/user/signin')">
                            Войти
                        </button>`;
                }
            }
        });
    </script>
</body>
</html>