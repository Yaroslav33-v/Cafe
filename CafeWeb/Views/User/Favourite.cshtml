@using System.Text.Json
@model CafeWeb.Models.Category?

<!DOCTYPE html>
<html>
<head>
    <link rel="icon" href="~/IMG/logo-cafe.png" type="image/png">
    <link href="~/CSS/favourite.css" rel="stylesheet" />
    <link href="~/CSS/header.css" rel="stylesheet" />
    <link href="~/CSS/footer.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <title> Избранное </title>
</head>
<body>
    <noscript>
        <!-- Отображается только если у пользователя выключен js в браузере -->
        <div style="background-color: #f44336; color: white; padding: 20px; text-align: center;">
            Для полноценной работы сайта включите JavaScript в настройках вашего браузера.
        </div>
    </noscript>
    <header>
        <div class="header-top">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo">
                        <img src="/IMG/logo-cafe.png" alt="Logo" onclick="goToPage('/cafe/index')" />
                    </div>
                </div>

                <nav class="header-nav">
                    <a href="/">Главная</a>
                    <a href="/about">О нас</a>
                    <a href="/user/OrderHistory">История заказов</a>
                </nav>

                <div class="header-actions">
                    <button class="btn-backk" onclick="goBackSafe('/cafe/index')">
                        <i class="fas fa-arrow-left"></i> Назад
                    </button>
                    <a href="/cafe/cart" class="cart-icon" title="Корзина">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <div id="profile-actions"></div>
                </div>
            </div>
        </div>
    </header>
    <div class="main-content">
        <div class="container">
            <div class="history-header">
                <button class="btn-back" onclick="goToPage('/user/me')">
                    <i class="fas fa-arrow-left"></i> Назад в профиль
                </button>
                <h1 class="history-title">Избранное</h1>
            </div>
            @if (Model is null || !Model.Foods.Any())
            {
                <div id="none-fav">
                    <p class="mes">В данный момент вы еще не добавили ни одного блюда в избранное</p>
                    <p class="mes">Иди скорее добавь что-нибудь!</p>
                    <button class="btn-go" onclick="goToPage('/cafe/index')">Посмотреть меню</button>
                </div>
            }
            else
            {
                <div class="main-menu">

                    <div class="category-items">
                        @foreach (var food in Model.Foods)
                        {
                            <div class="card" data-card-id="@food.Id">
                                <div onclick="openFoodModal(@JsonSerializer.Serialize(food), this)">
                                    <div class="card-images">
                                        <img id="front-img" width="300" height="200" src="@Url.Content($"~{food.FrontImageAddress}")" alt="@food.Name" class="front-image" />
                                        <img id="back-img" width="300" height="200" src="@Url.Content($"~{food.BackImageAddress}")" alt="@food.Name" class="back-image" />
                                    </div>
                                    <span class="card-title">@food.Name</span>
                                    <p class="card-title"><span>@food.Price</span> р</p>
                                </div>
                                <label id="price"></label>
                                <button class="addCart" type="button" onclick="addToCart(@food.Id)">Добавить в корзину</button>
                                <button class="modal-food-fav-btn liked" type="button" onclick="updateFavourite(@food.Id, this)"> </button>
                            </div>
                        }

                    </div>


                </div>
            }

        </div>
    </div>
    <footer class="footer">
        <div class="container-foot">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Подробнее о нашем кафе</h4>
                    <ul>
                        <li><i class="fas fa-building"></i><a href="/about#about">О нас</a></li>
                        <li><i class="fas fa-history"></i><a href="/about#story">Наша история</a></li>
                        <li><i class="fas fa-gem"></i><a href="/about#cinus">Наши ценности</a></li>
                        <li><i class="fas fa-chart-bar"></i><a href="/about#stats">Наша статистика</a></li>
                        <li><i class="fa-solid fa-pizza-slice"></i><a href="/about#meny">Меню</a></li>

                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Контакты и FAQ</h4>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> ул. Асаткина, 32</li>
                        <li><i class="fas fa-phone"></i> +7 (904) 033-08-49</li>
                        <li><i class="fas fa-clock"></i> Ежедневно с 9:00 до 23:00</li>
                        <li><i class="fas fa-envelope"></i> hello4tvorojka@mail.ru</li>
                        <li><i class="fas fa-question"></i><a href="/faq"> FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Мы в соцсетях</h4>
                    <ul>
                        <li><a href="https://vk.com/club236358484"><i class="fab fa-vk"></i> ВКонтакте</a></li>
                        <li><a href="https://t.me/FourTvorojka"><i class="fab fa-telegram"></i> Telegram</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Четыре творожка. Все права защищены.</p>
            </div>
        </div>
    </footer>
    <dialog id="food-modal">
        <div id="food-info">

            <h1 id="modal-food-name"></h1>
            <img id="modal-food-img-front" width="300" height="200" />
            <img id="modal-food-img-back" width="300" height="200" />

            <div>

                <p> Вес: <span id="modal-food-weight"></span> г.</p>
                <p id="modal-food-desc"></p>
                <p>Ингредиенты: <span id="modal-food-ingredients"></span></p>
                <p><span id="modal-food-calories"></span> ккал. на 100г. продукта</p>

            </div>
        </div>
        <div id="modal-controls">
            <button id="modal-food-cart-btn" type="button">Добавить <span id="modal-food-price"></span> р. </button>
            <button class="modal-food-fav-btn liked" type="button"></button>
            <button id="close-btn" type="button">Закрыть</button>
        </div>
    </dialog>
    <script src="~/JS/header.js"></script>
    <script src="~/JS/goToPage.js"></script>
    <script src="~/JS/showNotification.js"></script>
    <script src="~/JS/fav.js"></script>
</body>
</html>